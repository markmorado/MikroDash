
# ─────────────────────────────────────────────────────────────────────────────
# MikroDash — Environment Variables
#
# Settings are managed in two layers:
#   1. This file (env vars) — always wins on every restart.
#   2. /data/settings.json (Settings UI) — used for any field that does NOT
#      have a corresponding env var set here.
#
# Any env var you set here takes permanent precedence over the value stored
# in settings.json, so changing it here takes effect on the next container
# restart without needing to touch the UI.
# ─────────────────────────────────────────────────────────────────────────────


# ── Server ────────────────────────────────────────────────────────────────────
PORT=3081
MAX_SOCKETS=50
TRUSTED_PROXY=               # Proxy IP to trust X-Forwarded-For from (e.g. 127.0.0.1)


# ── Data volume & credential encryption ──────────────────────────────────────
# Set this to a long random string to protect credentials stored in settings.json.
# If unset, a built-in default is used (not recommended for production).
DATA_SECRET=


# ── RouterOS connection ───────────────────────────────────────────────────────
ROUTER_HOST=192.168.88.1
ROUTER_PORT=8729
ROUTER_TLS=true
ROUTER_TLS_INSECURE=false    # Set true to accept self-signed RouterOS certificates
ROUTER_USER=mikrodash
ROUTER_PASS=change-me
DEFAULT_IF=ether1            # WAN interface name used by the Bandwidth and Traffic cards


# ── Dashboard HTTP Basic Auth (optional) ──────────────────────────────────────
BASIC_AUTH_USER=
BASIC_AUTH_PASS=


# ── History & limits ──────────────────────────────────────────────────────────
HISTORY_MINUTES=30           # Traffic graph history window
MAX_CONNS=20000              # Max connection-table rows to process
TOP_N=10                     # Default Top-N for Connections page lists
TOP_TALKERS_N=5              # Top N talker IPs shown on the Bandwidth page
FIREWALL_TOP_N=15            # Top N entries shown on the Firewall page
VPN_DASH_TOP_N=5             # Top N WireGuard peers shown on the dashboard card
LOG_HISTORY_SIZE=500         # Number of log lines retained in memory


# ── Poll intervals (milliseconds) ────────────────────────────────────────────
SYSTEM_POLL_MS=1000
CONNS_POLL_MS=3000
BANDWIDTH_POLL_MS=3000
TALKERS_POLL_MS=3000
IFSTATUS_POLL_MS=3000
WIRELESS_POLL_MS=5000
PING_POLL_MS=5000
VPN_POLL_MS=10000
FIREWALL_POLL_MS=10000
ROUTING_POLL_MS=10000
ARP_POLL_MS=30000
DHCP_POLL_MS=600000


# ── Ping ──────────────────────────────────────────────────────────────────────
PING_TARGET=1.1.1.1


# ── Alert thresholds ─────────────────────────────────────────────────────────
ALERT_CPU_THRESHOLD=90       # CPU % spike notification threshold
ALERT_PING_LOSS=100          # Ping loss % threshold for loss alert


# ── Advanced / debugging ──────────────────────────────────────────────────────
ROS_WRITE_TIMEOUT_MS=30000
ROS_DEBUG=false              # Set true to enable verbose RouterOS API + wireless debug logging
